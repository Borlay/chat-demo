{
    "version": 1,
    "canisters": {
        "management": {
            "type": "motoko",
            "main": "src/management/main.mo"
        },
        "messages": {
            "type": "motoko",
            "main": "src/messages/main.mo"
        },
        "users": {
            "type": "motoko",
            "main": "src/users/main.mo"
        },
        "internet_identity": {
            "type": "pull",
            "id": "rdmx6-jaaaa-aaaaa-aaadq-cai"
